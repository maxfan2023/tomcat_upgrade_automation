          <mxGeometry x="840" y="950" width="480" height="22" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;Step_1 Verify Archive&lt;/b&gt;&lt;br&gt;Confirm JDK 11.0.31 tar.gz exists&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;missing -&amp;gt; prompt download and exit&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;Step_2 Check Current Version&lt;/b&gt;&lt;br&gt;Run jdk11/bin/java --version&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;already 11.0.31 -&amp;gt; exit&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;Step_3 Stop Services&lt;/b&gt;&lt;br&gt;Stop Ab Initio application services&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;prod-cont skips this step&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;Step_4 Extract New JDK&lt;/b&gt;&lt;br&gt;Install under /FCR_APP/abinitio/java&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;tar -xzf target archive&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1020" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;Step_5 Update Symlinks&lt;/b&gt;&lt;br&gt;Switch jdk11 and jdk1.8.0_191&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;record old JDK target first&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="&lt;b&gt;Step_6 Verify App Java&lt;/b&gt;&lt;br&gt;Confirm active version is 11.0.31&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;mismatch -&amp;gt; fail and exit&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="missing_archive" value="&lt;b&gt;Exit: Archive Missing&lt;/b&gt;&lt;br&gt;Download target JDK from Nexus first&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;do not continue the upgrade&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7ECEC;strokeColor=#D8C4C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="already_target" value="&lt;b&gt;Exit: Already Current&lt;/b&gt;&lt;br&gt;No service stop or restart needed&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;leave current state unchanged&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EAF5EC;strokeColor=#C0D5C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="app_failed" value="&lt;b&gt;Fail: App Version Mismatch&lt;/b&gt;&lt;br&gt;Stop workflow and write logs&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;check symlink and install dir&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7ECEC;strokeColor=#D8C4C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="&lt;b&gt;Step_7 Archive Old JDK&lt;/b&gt;&lt;br&gt;Create YYYYMMDD-suffixed tar.gz&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;optionally remove old folder&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1020" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="&lt;b&gt;Step_8 Update PG Hosts&lt;/b&gt;&lt;br&gt;Copy JDK, script, and config&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;ssh runs upgrade_jdk_on_db.sh&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="&lt;b&gt;Step_9 Start Services&lt;/b&gt;&lt;br&gt;Start Ab Initio application services&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;prod-cont skips this step&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="success" value="&lt;b&gt;Complete&lt;/b&gt;&lt;br&gt;Print the log file location&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;review logs for details&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EAF5EC;strokeColor=#C0D5C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1920" y="675" width="160" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg1" value="&lt;b&gt;PG_Step_1 Verify Target Dir&lt;/b&gt;&lt;br&gt;Confirm new JDK exists on DB host&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;missing directory -&amp;gt; fail&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
