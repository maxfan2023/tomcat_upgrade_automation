        </mxCell>
        <mxCell id="pg3" value="&lt;b&gt;PG_Step_3 Archive Old JDK&lt;/b&gt;&lt;br&gt;Compress old folder to tar.gz&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;optionally remove old folder&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
