        <mxCell id="pg4" value="&lt;b&gt;PG_Step_4 Verify DB Java&lt;/b&gt;&lt;br&gt;Confirm active version is 11.0.31&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;mismatch -&amp;gt; PG failure&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
