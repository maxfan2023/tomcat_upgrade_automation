        </mxCell>
        <mxCell id="pg2" value="&lt;b&gt;PG_Step_2 Update JDK-11&lt;/b&gt;&lt;br&gt;Switch the DB JDK symlink&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;record old jdk-11 target first&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Avenir Next;fontSize=13;" vertex="1" parent="1">
