        </mxCell>
        <mxCell id="frame_app_label" value="应用服务器" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#5E6976;fontFamily=Noto Sans SC;" vertex="1" parent="1">
          <mxGeometry x="98" y="130" width="320" height="22" as="geometry" />
        </mxCell>
        <mxCell id="frame_pg" value="" style="rounded=1;arcSize=14;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B7BEC7;strokeWidth=1.1;dashed=1;dashPattern=6 6;" vertex="1" parent="1">
          <mxGeometry x="820" y="970" width="1300" height="390" as="geometry" />
        </mxCell>
        <mxCell id="frame_pg_label" value="PostgreSQL 数据库服务器" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#5E6976;fontFamily=Noto Sans SC;" vertex="1" parent="1">
          <mxGeometry x="840" y="950" width="480" height="22" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;step_1 检查安装包&lt;/b&gt;&lt;br&gt;确认 JDK 11.0.31 tar.gz 存在&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;缺失 -&amp;gt; 提示下载并退出&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;step_2 检查当前版本&lt;/b&gt;&lt;br&gt;运行 jdk11/bin/java --version&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;已是 11.0.31 -&amp;gt; 直接退出&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;step_3 停止服务&lt;/b&gt;&lt;br&gt;停止 Ab Initio application services&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;prod-cont 跳过此步骤&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;step_4 解压新 JDK&lt;/b&gt;&lt;br&gt;安装到 /FCR_APP/abinitio/java&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;tar -xzf target archive&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1020" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="&lt;b&gt;step_5 更新软链接&lt;/b&gt;&lt;br&gt;切换 jdk11 和 jdk1.8.0_191&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;先记录旧 JDK 目标目录&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="&lt;b&gt;step_6 验证应用 Java&lt;/b&gt;&lt;br&gt;确认当前版本为 11.0.31&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;不匹配 -&amp;gt; 失败退出&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="240" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="missing_archive" value="&lt;b&gt;退出：安装包缺失&lt;/b&gt;&lt;br&gt;先从 Nexus 下载目标 JDK&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;不继续执行升级&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7ECEC;strokeColor=#D8C4C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="120" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="already_target" value="&lt;b&gt;退出：已是目标版本&lt;/b&gt;&lt;br&gt;无需停止或重启服务&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;保持当前状态&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EAF5EC;strokeColor=#C0D5C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="app_failed" value="&lt;b&gt;失败：应用版本不匹配&lt;/b&gt;&lt;br&gt;停止流程并写入日志&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;检查软链接和安装目录&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7ECEC;strokeColor=#D8C4C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="445" width="250" height="94" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="&lt;b&gt;step_7 归档旧 JDK&lt;/b&gt;&lt;br&gt;生成带 YYYYMMDD 的 tar.gz&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;可按配置删除旧目录&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1020" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="&lt;b&gt;step_8 更新 PG 主机&lt;/b&gt;&lt;br&gt;复制 JDK、脚本和配置&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;ssh 执行 upgrade_jdk_on_db.sh&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="&lt;b&gt;step_9 启动服务&lt;/b&gt;&lt;br&gt;启动 Ab Initio application services&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;prod-cont 跳过此步骤&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1620" y="675" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="success" value="&lt;b&gt;升级完成&lt;/b&gt;&lt;br&gt;打印日志文件位置&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;可查看详细执行记录&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EAF5EC;strokeColor=#C0D5C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1920" y="675" width="160" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg1" value="&lt;b&gt;pg_step_1 检查目标目录&lt;/b&gt;&lt;br&gt;确认 DB 主机已有新 JDK&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;目录不存在 -&amp;gt; 失败&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E7EEF8;strokeColor=#BCC9D9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="900" y="1095" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg2" value="&lt;b&gt;pg_step_2 更新 jdk-11&lt;/b&gt;&lt;br&gt;切换 DB JDK 软链接&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;先记录旧 jdk-11 目标&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7F4EF;strokeColor=#D4CDC3;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="1095" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg3" value="&lt;b&gt;pg_step_3 归档旧 JDK&lt;/b&gt;&lt;br&gt;压缩旧目录为 tar.gz&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;可按配置删除旧目录&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#EEE8F8;strokeColor=#C8BCD9;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1520" y="1095" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg4" value="&lt;b&gt;pg_step_4 验证 DB Java&lt;/b&gt;&lt;br&gt;确认版本为 11.0.31&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#5E6976&quot;&gt;不匹配 -&amp;gt; PG 失败&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#E8F3F0;strokeColor=#C0D3CC;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1830" y="1095" width="250" height="124" as="geometry" />
        </mxCell>
        <mxCell id="pg_failed" value="&lt;b&gt;失败：DB 验证不通过&lt;/b&gt;&lt;br&gt;停止并记录错误" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#F7ECEC;strokeColor=#D8C4C4;strokeWidth=1.2;shadow=0;overflow=hidden;fontFamily=Noto Sans SC;fontSize=13;" vertex="1" parent="1">
